<Window x:Class="TimetableScheduler.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="시간표 스케줄러"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="시간표 선택" Command="{Binding GoToSelectionCommand}"
                        Padding="12,6" Margin="0,0,4,0" />
                <Button Content="정보 입력" Command="{Binding GoToInputCommand}"
                        Padding="12,6" Margin="0,0,4,0" />
                <Button Content="해 미리보기" Command="{Binding GoToResultsCommand}"
                        Padding="12,6" Margin="0,0,4,0" />
                <Button Content="수동 편집" Command="{Binding GoToManualCommand}"
                        Padding="12,6" Margin="0,0,4,0" />
                <TextBlock Text="{Binding CurrentPage.Title}"
                           Foreground="White" VerticalAlignment="Center"
                           Margin="20,0,0,0" FontSize="14" FontWeight="Bold" />
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
    </Grid>
</Window>
