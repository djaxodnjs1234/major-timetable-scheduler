<UserControl x:Class="TimetableScheduler.Wpf.Controls.GradeLegendControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             IsHitTestVisible="False">
    <Border HorizontalAlignment="Right"
            Padding="6,3"
            Background="#F2FFFFFF"
            BorderBrush="#CCD4DA"
            BorderThickness="1"
            CornerRadius="4">
        <ItemsControl>
            <ItemsControl.ItemsSource>
                <x:Array Type="{x:Type sys:Int32}">
                    <sys:Int32>1</sys:Int32>
                    <sys:Int32>2</sys:Int32>
                    <sys:Int32>3</sys:Int32>
                    <sys:Int32>4</sys:Int32>
                    <sys:Int32>5</sys:Int32>
                </x:Array>
            </ItemsControl.ItemsSource>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,2,0"
                                BorderBrush="#555"
                                BorderThickness="1"
                                Background="{Binding Converter={StaticResource GradeToBrush}}" />
                        <TextBlock FontSize="10"
                                   Foreground="#333"
                                   VerticalAlignment="Center"
                                   Text="{Binding Converter={StaticResource AcademicLevelLabel}}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
