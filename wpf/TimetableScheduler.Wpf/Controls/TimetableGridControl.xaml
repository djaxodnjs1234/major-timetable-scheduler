<UserControl x:Class="TimetableScheduler.Wpf.Controls.TimetableGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:grid="clr-namespace:TimetableScheduler.ViewModel.Grid;assembly=TimetableScheduler.ViewModel"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=grid:TimetableGridViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#F0F0F0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="교시" FontWeight="Bold" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2,4" />
            <TextBlock Grid.Column="1" Text="시간" FontWeight="Bold" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2,4" />
            <TextBlock Grid.Column="2" Text="월" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" Padding="4" />
            <TextBlock Grid.Column="3" Text="화" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" Padding="4" />
            <TextBlock Grid.Column="4" Text="수" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" Padding="4" />
            <TextBlock Grid.Column="5" Text="목" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" Padding="4" />
            <TextBlock Grid.Column="6" Text="금" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Center" Padding="4" />
            <Border Grid.Column="2" BorderBrush="#666666" BorderThickness="2,0,0,0" IsHitTestVisible="False" />
            <Border Grid.Column="3" BorderBrush="#666666" BorderThickness="2,0,0,0" IsHitTestVisible="False" />
            <Border Grid.Column="4" BorderBrush="#666666" BorderThickness="2,0,0,0" IsHitTestVisible="False" />
            <Border Grid.Column="5" BorderBrush="#666666" BorderThickness="2,0,0,0" IsHitTestVisible="False" />
            <Border Grid.Column="6" BorderBrush="#666666" BorderThickness="2,0,0,0" IsHitTestVisible="False" />
        </Grid>

        <Grid Grid.Row="1" x:Name="BodyGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="32" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
                <RowDefinition Height="*" MinHeight="40" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="44" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
        </Grid>

    </Grid>
</UserControl>
