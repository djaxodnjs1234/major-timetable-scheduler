<UserControl x:Class="TimetableScheduler.Wpf.Views.DataInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:dom="clr-namespace:TimetableScheduler.Domain;assembly=TimetableScheduler.Domain"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DataInputViewModel}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#005FB8" />
        <SolidColorBrush x:Key="PrimaryLight" Color="#E5F0FF" />
        <SolidColorBrush x:Key="Surface" Color="#F5F7FA" />
        <SolidColorBrush x:Key="SurfaceContainer" Color="#ECEDF6" />
        <SolidColorBrush x:Key="OutlineVariant" Color="#C2C6D4" />
        <SolidColorBrush x:Key="OnSurface" Color="#191C21" />
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#424752" />

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariant}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,4,0" BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E1E2EA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryLight}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProfessorRowTemplate" DataType="{x:Type dom:Professor}">
            <Expander Margin="0,0,0,4" Expanded="OnProfessorExpanded">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Id}" FontWeight="Bold" Width="120" />
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </Expander.Header>
                <Border Background="White" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Margin="0,4" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4" Padding="6,4" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="이름" Margin="0,4" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4" Padding="6,4" />
                        </Grid>

                        <TextBlock Text="허용 강의실 (비우면 모든 강의실 가능)"
                                   FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                   Foreground="{StaticResource OnSurfaceVariant}" />
                        <ctrl:CheckListPickerControl x:Name="AllowedRoomsPicker" />

                        <TextBlock Text="불가 시간 (외래/겸임 출강)"
                                   FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                   Foreground="{StaticResource OnSurfaceVariant}" />
                        <ctrl:TimeSlotPickerControl x:Name="UnavailableSlotsPicker"
                                                    Width="380" HorizontalAlignment="Left" />

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="저장"
                                    Command="{Binding DataContext.SaveSelectedCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Click="OnProfessorSaveClick"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            <Button Content="삭제"
                                    Command="{Binding DataContext.DeleteSelectedCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Click="OnProfessorDeleteClick"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Expander>
        </DataTemplate>

        <!-- Shared field editor: binds to Sections[0], SaveGroup propagates to all sections -->
        <DataTemplate x:Key="CourseGroupRowTemplate" DataType="{x:Type vm:CourseGroupItem}">
            <Expander Margin="0,0,0,4" Expanded="OnCourseGroupExpanded">
                <Expander.Header>
                    <Border Padding="6,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportedFromExcel}" Value="True">
                                        <Setter Property="Background" Value="#F3F4F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" SharedSizeGroup="CourseCode" />
                            <ColumnDefinition Width="170" SharedSizeGroup="CourseName" />
                            <ColumnDefinition Width="58" SharedSizeGroup="CourseSections" />
                            <ColumnDefinition Width="98" SharedSizeGroup="CourseProfessor" />
                            <ColumnDefinition Width="56" SharedSizeGroup="CourseGrade" />
                            <ColumnDefinition Width="74" SharedSizeGroup="CourseHours" />
                            <ColumnDefinition Width="70" SharedSizeGroup="CourseBlocks" />
                            <ColumnDefinition Width="112" SharedSizeGroup="CourseUnavailableRooms" />
                            <ColumnDefinition Width="112" SharedSizeGroup="CourseCoteach" />
                            <ColumnDefinition Width="104" SharedSizeGroup="CourseFixedTimes" />
                            <ColumnDefinition Width="100" SharedSizeGroup="CourseCross" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding HeaderCode}" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="1" Text="{Binding HeaderName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="2" Text="{Binding HeaderSectionInfo}" Margin="6,0" />
                        <TextBlock Grid.Column="3" Text="{Binding HeaderProfessor}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="4" Text="{Binding HeaderGrade}" Margin="6,0" />
                        <TextBlock Grid.Column="5" Text="{Binding HeaderHours}" Margin="6,0" />
                        <TextBlock Grid.Column="6" Text="{Binding HeaderBlockStructure}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="7" Text="{Binding HeaderUnavailableRooms}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="8" Text="{Binding HeaderCoteachProfessors}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="9" Text="{Binding HeaderFixedTimes}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="10" Text="{Binding HeaderCrossGroups}" Foreground="{StaticResource OnSurfaceVariant}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                    </Grid>
                    </Border>
                </Expander.Header>
                <Border Background="White" Padding="16"
                        BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <StackPanel DataContext="{Binding Sections[0]}">
                        <!-- Section count controls (non-fixed groups only) -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                    Visibility="{Binding DataContext.IsFixedIndividual,
                                                 RelativeSource={RelativeSource AncestorType=Expander},
                                                 Converter={StaticResource BoolToVisibility},
                                                 ConverterParameter=Inverse}">
                            <TextBlock Text="분반 수:"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,8,0" Foreground="{StaticResource OnSurfaceVariant}" />
                            <TextBlock Text="{Binding DataContext.Sections.Count,
                                               RelativeSource={RelativeSource AncestorType=Expander}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="+" Click="OnAddSectionClick"
                                    Padding="10,4" Margin="0,0,4,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            <Button Content="-" Click="OnRemoveSectionClick"
                                    Padding="10,4"
                                    Background="{StaticResource SurfaceContainer}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="수정"
                                    Command="{Binding DataContext.EditCourseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Expander}}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}" />
                            <TextBlock Text="기본 정보와 운영 정보는 수정 버튼을 누른 뒤 편집할 수 있습니다."
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource OnSurfaceVariant}" />
                        </StackPanel>

                        <Border Background="#FAFAFA"
                                BorderBrush="{StaticResource OutlineVariant}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,10"
                                Margin="0,2,0,12"
                                IsEnabled="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}}">
                            <StackPanel>
                                <TextBlock Text="기본 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />
                                <WrapPanel>
                                    <StackPanel Width="170" Margin="0,0,8,8">
                                        <TextBlock Text="이름 (읽기 전용)" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="170"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4">
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Width="66" Margin="0,0,8,8">
                                        <TextBlock Text="학년" FontSize="11" Margin="0,0,0,3" />
                                        <ComboBox Height="28" Width="60" Padding="6,3"
                                                   ItemsSource="{Binding DataContext.GradeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   SelectedItem="{Binding Grade, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Width="82" Margin="0,0,8,8">
                                        <TextBlock Text="주당 수업시간" FontSize="11" Margin="0,0,0,3" />
                                        <ComboBox Height="28" Width="76" Padding="6,3"
                                                   ItemsSource="{Binding DataContext.HourOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   SelectedItem="{Binding HoursPerWeek, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Width="78" Margin="0,0,8,8">
                                        <TextBlock Text="유형" FontSize="11" Margin="0,0,0,3" />
                                        <ComboBox Height="28" Width="72" Padding="6,3"
                                                   ItemsSource="{Binding DataContext.CourseTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   SelectedItem="{Binding CourseType, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Width="110" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="블록구조" FontSize="11" />
                                            <TextBlock Text=" (?)" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="한 과목의 주당 시간이 나뉘는 방식입니다. 예: 주당 3시간 과목은 보통 2시간+1시간 블록입니다." />
                                        </StackPanel>
                                        <ComboBox Height="28" Width="104" Padding="6,3"
                                                  ItemsSource="{Binding DataContext.BlockStructureOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding BlockStructure, Mode=TwoWay, Converter={StaticResource IntListToCsv}}" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#FAFAFA"
                                BorderBrush="{StaticResource OutlineVariant}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,10"
                                IsEnabled="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}}">
                            <StackPanel>
                                <TextBlock Text="운영 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="교수" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}" />
                                <ComboBox Height="30" MaxWidth="180" HorizontalAlignment="Left" Padding="6,3"
                                          ItemsSource="{Binding DataContext.Workspace.Professors, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding ProfessorId, Mode=TwoWay}" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                                    <TextBlock Text="불가 강의실"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}" />
                                    <TextBlock Text=" (?)" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                               ToolTip="교수의 강의실 선호보다 교과목의 불가 강의실 회피가 먼저 적용됩니다." />
                                </StackPanel>
                                <ctrl:CheckListPickerControl x:Name="GroupUnavailableRoomsPicker" />

                                <TextBlock Text="팀티칭 교수"
                                           FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}" />
                                <ctrl:CheckListPickerControl x:Name="GroupCoteachProfsPicker" />

                                <TextBlock Text="Cross 설정"
                                           FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}" />
                                <ctrl:CheckListPickerControl x:Name="GroupCrossPicker" />

                                <CheckBox Content="시간 고정"
                                          IsChecked="{Binding IsFixed, Mode=TwoWay}"
                                          Margin="0,16,0,4" FontWeight="Bold"
                                          Checked="OnIsFixedCheckChanged"
                                          Unchecked="OnIsFixedCheckChanged" />

                                <ctrl:FixedSlotEditorControl x:Name="FixedSlotEditor" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="저장"
                                    Click="OnCourseGroupSaveClick"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            <Button Content="삭제"
                                    Click="OnCourseGroupDeleteClick"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="RoomRowTemplate" DataType="{x:Type dom:Room}">
            <Expander Margin="0,0,0,4">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Id}" FontWeight="Bold" Width="120" />
                        <TextBlock Text="{Binding Name}" />
                    </StackPanel>
                </Expander.Header>
                <Border Background="White" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ID" Margin="0,4" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4" Padding="6,4" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="이름" Margin="0,4" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4" Padding="6,4" />

                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="저장"
                                    Command="{Binding DataContext.SaveSelectedCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            <Button Content="삭제"
                                    Command="{Binding DataContext.DeleteSelectedCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Expander>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="2" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="정보 입력" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="교과목·교수·강의실 정보를 입력하고 시간표를 자동 생성합니다."
                               Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,16,16,12">
                    <StackPanel>
                        <TextBlock Text="RESOURCE EXPLORER"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="Bold" FontSize="11" />
                        <TextBlock Text="Database v2.4"
                                   Foreground="{StaticResource OnSurfaceVariant}"
                                   FontSize="10" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="16,12" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Content="📥 교과목 편람 불러오기 (.xlsx)"
                                Click="OnImportXlsxClick"
                                Padding="8,6"
                                HorizontalContentAlignment="Left"
                                Background="White" BorderBrush="{StaticResource OutlineVariant}" />

                        <Button Content="수동 편집으로 →"
                                Command="{Binding GoToManualCommand}"
                                Margin="0,12,0,0"
                                Style="{StaticResource SidebarManualEditButton}"
                                IsEnabled="{Binding IsExistingMode}" />
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,8">
                    <TextBlock Text="정보 관리" Margin="16,4"
                               Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" />
                    <RadioButton Content="📚 교과목 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsCourseSelected, Mode=OneWay}"
                                 Command="{Binding SelectCourseCommand}"
                                 GroupName="DataNav" />
                    <RadioButton Content="👥 교수 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsProfessorSelected, Mode=OneWay}"
                                 Command="{Binding SelectProfessorCommand}"
                                 GroupName="DataNav" />
                    <RadioButton Content="🚪 강의실 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsRoomSelected, Mode=OneWay}"
                                 Command="{Binding SelectRoomCommand}"
                                 GroupName="DataNav" />

                    <TextBlock Text="실행" Margin="16,12,16,4"
                               Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" />
                    <RadioButton Content="★ 시간표 자동 생성" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsSolveSelected, Mode=OneWay}"
                                 Command="{Binding SelectSolveCommand}"
                                 GroupName="DataNav" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Padding="24,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource OnSurface}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="교수 정보 관리" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCourseSelected}" Value="True">
                                        <Setter Property="Text" Value="교과목 정보 관리" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRoomSelected}" Value="True">
                                        <Setter Property="Text" Value="강의실 정보 관리" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSolveSelected}" Value="True">
                                        <Setter Property="Text" Value="시간표 자동 생성" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Add Row (CRUD only) -->
            <Border Grid.Row="1" Margin="24,0,24,16" Padding="12"
                    Background="White" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSolveSelected}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ID:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCourseSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBox Width="140" Padding="6,4"
                             Text="{Binding NewId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,12,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCourseSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="이름:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                    <TextBox Width="200" Padding="6,4"
                             Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,12,0" />
                    <Button Content="+ 추가" Command="{Binding AddNewCommand}"
                            Padding="12,4" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                </StackPanel>
            </Border>

            <!-- List or Solve panel -->
            <Border Grid.Row="2" Margin="24,0,24,24" Background="White"
                    BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel Visibility="{Binding IsProfessorSelected, Converter={StaticResource BoolToVisibility}}" Margin="8">
                            <Grid Background="#EEF0F4" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="교수" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="1" Text="이름" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="설정" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Workspace.Professors}"
                                          ItemTemplate="{StaticResource ProfessorRowTemplate}" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsCourseSelected, Converter={StaticResource BoolToVisibility}}" Margin="8"
                                    Grid.IsSharedSizeScope="True">
                            <Grid Background="#EEF0F4" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" SharedSizeGroup="CourseCode" />
                                    <ColumnDefinition Width="170" SharedSizeGroup="CourseName" />
                                    <ColumnDefinition Width="58" SharedSizeGroup="CourseSections" />
                                    <ColumnDefinition Width="98" SharedSizeGroup="CourseProfessor" />
                                    <ColumnDefinition Width="56" SharedSizeGroup="CourseGrade" />
                                    <ColumnDefinition Width="74" SharedSizeGroup="CourseHours" />
                                    <ColumnDefinition Width="70" SharedSizeGroup="CourseBlocks" />
                                    <ColumnDefinition Width="112" SharedSizeGroup="CourseUnavailableRooms" />
                                    <ColumnDefinition Width="112" SharedSizeGroup="CourseCoteach" />
                                    <ColumnDefinition Width="104" SharedSizeGroup="CourseFixedTimes" />
                                    <ColumnDefinition Width="100" SharedSizeGroup="CourseCross" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="교과목" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="1" Text="이름" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="분반" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="3" Text="교수" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="4" Text="학년" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="5" Text="시수" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="6" Text="블록" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="7" Text="불가 강의실" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="8" Text="팀티칭 교수" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="9" Text="시간 고정" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="10" Text="Cross" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding CourseGroups}"
                                          ItemTemplate="{StaticResource CourseGroupRowTemplate}" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsRoomSelected, Converter={StaticResource BoolToVisibility}}" Margin="8">
                            <Grid Background="#EEF0F4" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="강의실" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="1" Text="이름" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="설정" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Workspace.Rooms}"
                                          ItemTemplate="{StaticResource RoomRowTemplate}" />
                        </StackPanel>

                        <!-- Solve panel -->
                        <StackPanel Margin="32,24"
                                    Visibility="{Binding IsSolveSelected, Converter={StaticResource BoolToVisibility}}">

                            <TextBlock Text="제약 조건 (Soft Constraints)"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <StackPanel>
                                    <CheckBox Content="SC-01  월요일 오전 / 금요일 오후 회피"
                                              IsChecked="{Binding UseSc01}" Margin="0,4" />
                                    <CheckBox Content="SC-02  교수당 강의 요일 ≤ 3"
                                              IsChecked="{Binding UseSc02}" Margin="0,4" />
                                    <CheckBox Content="SC-03  같은 과목 블록 사이 요일 간격 ≥ 2"
                                              IsChecked="{Binding UseSc03}" Margin="0,4" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="솔버 파라미터" FontSize="14" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="해 후보 수 (top M)" Margin="0,4" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Padding="6,4" Margin="0,4" Width="120" HorizontalAlignment="Left"
                                             Text="{Binding TotalSolutions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="제한 시간 (초)" Margin="0,4" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Padding="6,4" Margin="0,4" Width="120" HorizontalAlignment="Left"
                                             Text="{Binding TimeLimitSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Border>

                            <TextBlock Text="진행 상황" FontSize="14" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding StatusMessage}" Margin="0,0,0,8" />
                                    <ProgressBar Height="8" Margin="0,0,0,8"
                                                 Maximum="{Binding ProgressTotal}"
                                                 Value="{Binding ProgressCurrent}" />
                                    <TextBlock>
                                        <Run Text="{Binding ProgressCurrent, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding ProgressTotal, Mode=OneWay}" />
                                        <Run Text="   고유해 " />
                                        <Run Text="{Binding UniqueSolutionsFound, Mode=OneWay}" FontWeight="Bold" />
                                        <Run Text=" 개" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="시간표 자동 생성 (해 계산)"
                                        Command="{Binding SolveCommand}"
                                        Padding="20,10" FontWeight="Bold" FontSize="13"
                                        Margin="0,0,8,0">
                                    <Button.Style>
                                        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="취소" Command="{Binding CancelCommand}"
                                        Padding="14,10"
                                        IsEnabled="{Binding IsSolving}" />
                                <Button Content="해 미리보기로 →"
                                        Command="{Binding GoToSelectionCommand}"
                                        Padding="14,10" Margin="8,0,0,0"
                                        Background="#2E7D32" Foreground="White"
                                        Visibility="{Binding IsSolveComplete, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
