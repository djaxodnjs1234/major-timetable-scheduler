<UserControl x:Class="TimetableScheduler.Wpf.Views.DataInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:dom="clr-namespace:TimetableScheduler.Domain;assembly=TimetableScheduler.Domain"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:DataInputViewModel}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#005FB8" />
        <SolidColorBrush x:Key="PrimaryLight" Color="#E5F0FF" />
        <SolidColorBrush x:Key="Surface" Color="#F5F7FA" />
        <SolidColorBrush x:Key="SurfaceContainer" Color="#ECEDF6" />
        <SolidColorBrush x:Key="OutlineVariant" Color="#C2C6D4" />
        <SolidColorBrush x:Key="OnSurface" Color="#191C21" />
        <SolidColorBrush x:Key="OnSurfaceVariant" Color="#424752" />

        <Style x:Key="DataInputComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource DataInputComboBoxItemStyle}" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariant}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,4,0" BorderBrush="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E1E2EA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryLight}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProfessorRowTemplate" DataType="{x:Type vm:ProfessorItem}">
            <Expander Margin="0,0,0,4" Expanded="OnProfessorExpanded">
                <Expander.Header>
                    <Border Padding="6,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportedFromExcel}" Value="True">
                                        <Setter Property="Background" Value="#F3F4F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" SharedSizeGroup="ProfessorId" />
                                <ColumnDefinition Width="180" SharedSizeGroup="ProfessorName" />
                                <ColumnDefinition Width="220" SharedSizeGroup="ProfessorUnavailableSlots" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HeaderId}" FontWeight="Bold" Margin="6,0" />
                            <TextBlock Grid.Column="1" Text="{Binding HeaderName}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                            <TextBlock Grid.Column="2" Text="{Binding HeaderUnavailableSlots}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        </Grid>
                    </Border>
                </Expander.Header>
                <Border Background="White" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <StackPanel>
                        <Border Background="#FAFAFA"
                                 BorderBrush="{StaticResource OutlineVariant}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="12,10"
                                 Margin="0,2,0,12">
                            <StackPanel>
                                <TextBlock Text="기본 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />
                                <WrapPanel>
                                    <StackPanel Width="170" Margin="0,0,8,8">
                                        <TextBlock Text="이름 (읽기 전용)" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="170"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4">
                                            <TextBlock Text="{Binding Professor.Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Professor.Name}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#FAFAFA"
                                 BorderBrush="{StaticResource OutlineVariant}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="운영 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />

                                <WrapPanel Margin="0,0,0,8"
                                           Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                    <TextBlock Text="불가 시간: " FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}" />
                                    <TextBlock Text="{Binding HeaderUnavailableSlots}"
                                               FontSize="11" />
                                </WrapPanel>

                                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="불가 시간 (외래/겸임 출강)"
                                               FontSize="11" FontWeight="Bold" Margin="0,4,0,4"
                                               Foreground="{StaticResource OnSurfaceVariant}" />
                                    <ctrl:TimeSlotPickerControl x:Name="UnavailableSlotsPicker"
                                                                 Width="400" HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="수정"
                                    Command="{Binding DataContext.EditProfessorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />
                            <Button Content="완료"
                                    Click="OnProfessorSaveClick"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="취소"
                                    Click="OnProfessorCancelClick"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="삭제"
                                    Click="OnProfessorDeleteClick"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Expander>
        </DataTemplate>

        <!-- Shared field editor: binds to an edit copy; SaveGroup propagates to all sections -->
        <DataTemplate x:Key="CourseGroupRowTemplate" DataType="{x:Type vm:CourseGroupItem}">
            <Expander Margin="0,0,0,4" Expanded="OnCourseGroupExpanded">
                <Expander.Header>
                    <Border Padding="6,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportedFromExcel}" Value="True">
                                        <Setter Property="Background" Value="#F3F4F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72" SharedSizeGroup="CourseCode" />
                            <ColumnDefinition Width="170" SharedSizeGroup="CourseName" />
                            <ColumnDefinition Width="58" SharedSizeGroup="CourseSections" />
                            <ColumnDefinition Width="98" SharedSizeGroup="CourseProfessor" />
                            <ColumnDefinition Width="52" SharedSizeGroup="CourseType" />
                            <ColumnDefinition Width="68" SharedSizeGroup="CourseGrade" />
                            <ColumnDefinition Width="74" SharedSizeGroup="CourseHours" />
                            <ColumnDefinition Width="70" SharedSizeGroup="CourseBlocks" />
                            <ColumnDefinition Width="112" SharedSizeGroup="CourseCoteach" />
                            <ColumnDefinition Width="112" SharedSizeGroup="CourseUnavailableRooms" />
                            <ColumnDefinition Width="112" SharedSizeGroup="CourseFixedRooms" />
                            <ColumnDefinition Width="104" SharedSizeGroup="CourseFixedTimes" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="6,0">
                            <TextBlock Text="{Binding HeaderFixedMarker}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Width="14" />
                            <TextBlock Text="{Binding HeaderCode}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding HeaderName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="2" Text="{Binding HeaderSectionInfo}" Margin="6,0" />
                        <TextBlock Grid.Column="3" Text="{Binding HeaderProfessor}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="4" Text="{Binding HeaderCourseType}" Margin="6,0" />
                        <TextBlock Grid.Column="5" Text="{Binding HeaderGrade}" Margin="6,0" />
                        <TextBlock Grid.Column="6" Text="{Binding HeaderHours}" Margin="6,0" />
                        <TextBlock Grid.Column="7" Text="{Binding HeaderBlockStructure}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="8" Text="{Binding HeaderCoteachProfessors}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="9" Text="{Binding HeaderUnavailableRooms}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="10" Text="{Binding HeaderFixedRooms}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                        <TextBlock Grid.Column="11" Text="{Binding HeaderFixedTimes}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                    </Grid>
                    </Border>
                </Expander.Header>
                <Border Background="White" Padding="16"
                        BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <StackPanel DataContext="{Binding Sections[0]}">
                        <!-- Section count controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="분반 수:"
                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Center"
                                       Margin="0,0,8,0" Foreground="{StaticResource OnSurfaceVariant}" />
                            <TextBlock Text="{Binding DataContext.Sections.Count,
                                               RelativeSource={RelativeSource AncestorType=Expander}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="+" Click="OnAddSectionClick"
                                    Padding="10,4" Margin="0,0,4,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" />
                            <Button Content="-" Click="OnRemoveSectionClick"
                                    Padding="10,4"
                                    Background="{StaticResource SurfaceContainer}" />
                        </StackPanel>
                        <Border Background="#FAFAFA"
                                 BorderBrush="{StaticResource OutlineVariant}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="12,10"
                                 Margin="0,2,0,12">
                            <StackPanel>
                                <TextBlock Text="기본 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />
                                <WrapPanel>
                                    <StackPanel Width="170" Margin="0,0,8,8">
                                        <TextBlock Text="이름 (읽기 전용)" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="170"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4">
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Name}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Width="78" Margin="0,0,8,8">
                                        <TextBlock Text="학년" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="72"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding Grade, Converter={StaticResource AcademicLevelLabel}}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ComboBox x:Name="CourseGradeComboBox"
                                                  Height="28" Width="72" Padding="6,3"
                                                    ItemsSource="{Binding DataContext.GradeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    SelectedValue="{Binding Grade, Mode=TwoWay}"
                                                    SelectedValuePath="Grade"
                                                    DisplayMemberPath="DisplayName"
                                                    Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                    <StackPanel Width="82" Margin="0,0,8,8">
                                        <TextBlock Text="주당 수업시간" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="76"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding HoursPerWeek}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ComboBox Height="28" Width="76" Padding="6,3"
                                                    ItemsSource="{Binding DataContext.HourOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    SelectedItem="{Binding HoursPerWeek, Mode=TwoWay}"
                                                    SelectionChanged="OnCourseHoursChanged"
                                                    Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                    <StackPanel Width="78" Margin="0,0,8,8">
                                        <TextBlock Text="유형" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="72"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding CourseType}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ComboBox x:Name="CourseTypeComboBox"
                                                  Height="28" Width="72" Padding="6,3"
                                                  ItemsSource="{Binding DataContext.CourseTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding CourseType, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                  SelectionChanged="OnCourseSharedSelectionChanged"
                                                  Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                    <StackPanel Width="92" Margin="0,0,8,8"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="학교 고정" FontSize="11" Margin="0,0,0,3" />
                                        <CheckBox x:Name="SchoolFixedCheckBox"
                                                  Height="28"
                                                  IsChecked="{Binding IsSchoolFixed, Mode=TwoWay}"
                                                  Checked="OnSchoolFixedCheckChanged"
                                                  Unchecked="OnSchoolFixedCheckChanged" />
                                    </StackPanel>
                                    <StackPanel Width="92" Margin="0,0,8,8"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="적용 범위" FontSize="11" Margin="0,0,0,3" />
                                        <ComboBox Height="28" Width="86" Padding="6,3"
                                                  ItemsSource="{Binding DataContext.SchoolFixedTargetOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedValue="{Binding SchoolFixedTargetGrade, Mode=TwoWay}"
                                                  SelectedValuePath="Grade"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectionChanged="OnCourseSharedSelectionChanged" />
                                    </StackPanel>
                                    <StackPanel Width="110" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="블록구조" FontSize="11" />
                                            <TextBlock Text=" (?)" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="한 과목의 주당 시간이 나뉘는 방식입니다.&#x0a;예: 주당 3시간 과목은 보통 2시간+1시간 블록입니다." />
                                        </StackPanel>
                                        <Border Height="28" Width="104"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding DataContext.ReadOnlyBlockStructure, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <ComboBox x:Name="BlockStructureComboBox"
                                                  Height="28" Width="104" Padding="6,3"
                                                  ItemsSource="{Binding DataContext.BlockStructureOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding BlockStructure, Mode=TwoWay, Converter={StaticResource IntListToCsv}, UpdateSourceTrigger=Explicit}"
                                                  SelectionChanged="OnCourseBlockStructureChanged"
                                                  Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#FAFAFA"
                                 BorderBrush="{StaticResource OutlineVariant}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="운영 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />

                                <StackPanel Margin="0,0,0,8"
                                            Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                    <TextBlock Text="{Binding DataContext.ReadOnlyProfessor, RelativeSource={RelativeSource AncestorType=Expander}, StringFormat=담당교수: {0}}"
                                               FontSize="11"
                                               Foreground="{StaticResource OnSurfaceVariant}" />
                                    <TextBlock Text="{Binding DataContext.ReadOnlyCoteachProfessors, RelativeSource={RelativeSource AncestorType=Expander}, StringFormat=팀티칭 교수: {0}}"
                                               FontSize="11"
                                               Foreground="{StaticResource OnSurfaceVariant}"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DataContext.ReadOnlyUnavailableRooms, RelativeSource={RelativeSource AncestorType=Expander}, StringFormat=불가 강의실: {0}}"
                                               FontSize="11"
                                               Foreground="{StaticResource OnSurfaceVariant}"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DataContext.ReadOnlyFixedRooms, RelativeSource={RelativeSource AncestorType=Expander}, StringFormat=강의실(다중 선택 가능): {0}}"
                                               FontSize="11"
                                               Foreground="{StaticResource OnSurfaceVariant}"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DataContext.ReadOnlyFixedTimes, RelativeSource={RelativeSource AncestorType=Expander}, StringFormat=시간 고정: {0}}"
                                               FontSize="11"
                                               Foreground="{StaticResource OnSurfaceVariant}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBlock Text="분반별 담당교수"
                                           FontSize="11" FontWeight="Bold" Margin="0,4,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                <ItemsControl x:Name="SectionProfessorItemsControl"
                                              ItemsSource="{Binding DataContext.Sections, RelativeSource={RelativeSource AncestorType=Expander}}"
                                              Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Width="52"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding SectionLabel, StringFormat={}{0}분반}" />
                                                <ComboBox Height="30" Width="180" Padding="6,3"
                                                          ItemsSource="{Binding DataContext.Workspace.Professors, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding ProfessorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="팀티칭 교수"
                                           FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                <ctrl:CheckListPickerControl x:Name="GroupCoteachProfsPicker"
                                                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,4"
                                            Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="불가 강의실"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource OnSurfaceVariant}" />
                                    <TextBlock Text=" (?)" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                               ToolTip="설정한 강의실은 배정되지 않습니다." />
                                    <Button x:Name="CourseUnavailableLabRoomsButton"
                                            Content="실습실"
                                            Click="OnCourseUnavailableLabRoomsClick"
                                            Padding="8,2"
                                            Margin="12,0,0,0"
                                            Background="{StaticResource SurfaceContainer}" />
                                    <Button x:Name="CourseUnavailableNonLabRoomsButton"
                                            Content="비실습실"
                                            Click="OnCourseUnavailableNonLabRoomsClick"
                                            Padding="8,2"
                                            Margin="4,0,0,0"
                                            Background="{StaticResource SurfaceContainer}" />
                                    <Button x:Name="CourseUnavailableClearRoomsButton"
                                            Content="전체 해제"
                                            Click="OnCourseUnavailableClearRoomsClick"
                                            Padding="8,2"
                                            Margin="4,0,0,0"
                                            Background="{StaticResource SurfaceContainer}" />
                                </StackPanel>
                                <ctrl:CheckListPickerControl x:Name="GroupUnavailableRoomsPicker"
                                                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="강의실 (다중 선택 가능)"
                                           FontSize="11" FontWeight="Bold" Margin="0,12,0,4"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                                <ctrl:CheckListPickerControl x:Name="GroupFixedRoomsPicker"
                                                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />

                                <CheckBox x:Name="IsFixedCheckBox"
                                          Content="시간 고정"
                                          IsChecked="{Binding IsFixed, Mode=TwoWay}"
                                          Margin="0,16,0,4" FontWeight="Bold"
                                          Checked="OnIsFixedCheckChanged"
                                          Unchecked="OnIsFixedCheckChanged"
                                          Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />

                                <ctrl:FixedSlotEditorControl x:Name="FixedSlotEditor"
                                                             DataContext="{Binding DataContext.FixedSlotEditor, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                             Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="수정"
                                    Command="{Binding DataContext.EditCourseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Expander}}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />
                            <Button Content="완료"
                                    Click="OnCourseGroupSaveClick"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                                    Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="취소"
                                    Click="OnCourseGroupCancelClick"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding DataContext.IsEditing, RelativeSource={RelativeSource AncestorType=Expander}, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="삭제"
                                    Click="OnCourseGroupDeleteClick"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="RoomRowTemplate" DataType="{x:Type vm:RoomItem}">
            <Expander Margin="0,0,0,4">
                <Expander.Header>
                    <Border Padding="6,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsImportedFromExcel}" Value="True">
                                        <Setter Property="Background" Value="#F3F4F6" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" SharedSizeGroup="RoomId" />
                                <ColumnDefinition Width="170" SharedSizeGroup="RoomName" />
                                <ColumnDefinition Width="70" SharedSizeGroup="RoomLab" />
                                <ColumnDefinition Width="82" SharedSizeGroup="RoomCapacity" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding HeaderId}" FontWeight="Bold" Margin="6,0" />
                            <TextBlock Grid.Column="1" Text="{Binding HeaderName}" TextTrimming="CharacterEllipsis" Margin="6,0" />
                            <TextBlock Grid.Column="2" Text="{Binding HeaderLab}" Margin="6,0" />
                            <TextBlock Grid.Column="3" Text="{Binding HeaderCapacity}" Margin="6,0" />
                        </Grid>
                    </Border>
                </Expander.Header>
                <Border Background="White" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                    <StackPanel>
                        <Border Background="#FAFAFA"
                                 BorderBrush="{StaticResource OutlineVariant}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="12,10"
                                 Margin="0,2,0,12">
                            <StackPanel>
                                <TextBlock Text="기본 정보"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource OnSurfaceVariant}"
                                           Margin="0,0,0,8" />
                                <WrapPanel>
                                    <StackPanel Width="170" Margin="0,0,8,8">
                                        <TextBlock Text="이름 (읽기 전용)" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="170"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4">
                                            <TextBlock Text="{Binding Room.Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Width="80" Margin="0,0,8,8">
                                        <TextBlock Text="구분" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="74"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding HeaderLab}" VerticalAlignment="Center" />
                                        </Border>
                                        <CheckBox Content="실습실" IsChecked="{Binding Room.IsLab, Mode=TwoWay}"
                                                  Height="28" VerticalAlignment="Center" Margin="4,0,0,0"
                                                  Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                    <StackPanel Width="120" Margin="0,0,8,8">
                                        <TextBlock Text="허용 인원" FontSize="11" Margin="0,0,0,3" />
                                        <Border Height="28" Width="114"
                                                Background="#F3F4F6"
                                                BorderBrush="{StaticResource OutlineVariant}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="6,4"
                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                            <TextBlock Text="{Binding HeaderCapacity}" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBox Height="28" Width="114" Padding="6,4"
                                                 Text="{Binding Room.Capacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="수정"
                                    Command="{Binding DataContext.EditRoomCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />
                            <Button Content="완료"
                                    Command="{Binding DataContext.SaveRoomCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="취소"
                                    Command="{Binding DataContext.CancelRoomCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Background="{StaticResource SurfaceContainer}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />
                            <Button Content="삭제"
                                    Click="OnRoomDeleteClick"
                                    Padding="12,6"
                                    Background="#BA1A1A" Foreground="White" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Expander>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="2" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="정보 입력" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="교과목·교수·강의실 정보를 입력하고 시간표를 자동 생성합니다."
                               Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#F8F9FA" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,16,16,12">
                    <StackPanel>
                        <TextBlock Text="RESOURCE EXPLORER"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="Bold" FontSize="11" />
                        <TextBlock Text="Database v2.4"
                                   Foreground="{StaticResource OnSurfaceVariant}"
                                   FontSize="10" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="16,12" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Content="📥 교과목 편람 불러오기 (.xlsx)"
                                Click="OnImportXlsxClick"
                                Padding="8,6"
                                HorizontalContentAlignment="Left"
                                Background="White" BorderBrush="{StaticResource OutlineVariant}" />

                        <Button Content="수동 편집으로 →"
                                Command="{Binding GoToManualCommand}"
                                Margin="0,12,0,0"
                                Style="{StaticResource SidebarManualEditButton}"
                                IsEnabled="{Binding IsExistingMode}" />
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,8">
                    <TextBlock Text="정보 관리" Margin="16,4"
                               Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" />
                    <RadioButton Content="📚 교과목 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsCourseSelected, Mode=OneWay}"
                                 Command="{Binding SelectCourseCommand}"
                                 GroupName="DataNav" />
                    <RadioButton Content="👥 교수 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsProfessorSelected, Mode=OneWay}"
                                 Command="{Binding SelectProfessorCommand}"
                                 GroupName="DataNav" />
                    <RadioButton Content="🚪 강의실 정보" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsRoomSelected, Mode=OneWay}"
                                 Command="{Binding SelectRoomCommand}"
                                 GroupName="DataNav" />

                    <TextBlock Text="실행" Margin="16,12,16,4"
                               Foreground="#9CA3AF" FontSize="10" FontWeight="Bold" />
                    <RadioButton Content="★ 시간표 자동 생성" Style="{StaticResource NavButtonStyle}"
                                 IsChecked="{Binding IsSolveSelected, Mode=OneWay}"
                                 Command="{Binding SelectSolveCommand}"
                                 GroupName="DataNav" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Padding="24,16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource OnSurface}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="교수 정보 관리" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCourseSelected}" Value="True">
                                        <Setter Property="Text" Value="교과목 정보 관리" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRoomSelected}" Value="True">
                                        <Setter Property="Text" Value="강의실 정보 관리" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSolveSelected}" Value="True">
                                        <Setter Property="Text" Value="시간표 자동 생성" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Add Row (CRUD only) -->
            <Border Grid.Row="1" Margin="24,0,24,16" Padding="12"
                    Background="White" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSolveSelected}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="이름:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                    <TextBox Width="200" Padding="6,4"
                             Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,12,0" />
                    <Button Content="+ 추가" Command="{Binding AddNewCommand}"
                            Padding="12,4" Background="{StaticResource PrimaryBrush}" Foreground="White" />
                </StackPanel>
            </Border>

            <!-- List or Solve panel -->
            <Border Grid.Row="2" Margin="24,0,24,24" Background="White"
                    BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel Visibility="{Binding IsProfessorSelected, Converter={StaticResource BoolToVisibility}}" Margin="8" Background="#F3F4F6"
                                    Grid.IsSharedSizeScope="True">
                            <Grid Background="{StaticResource PrimaryBrush}" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="72" SharedSizeGroup="ProfessorId" />
                                    <ColumnDefinition Width="180" SharedSizeGroup="ProfessorName" />
                                    <ColumnDefinition Width="220" SharedSizeGroup="ProfessorUnavailableSlots" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="교수 ID" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="이름" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="3" Text="불가 시간" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ProfessorItems}"
                                          ItemTemplate="{StaticResource ProfessorRowTemplate}" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsCourseSelected, Converter={StaticResource BoolToVisibility}}" Margin="8"
                                    Background="#F3F4F6"
                                    Grid.IsSharedSizeScope="True">
                            <Grid Background="{StaticResource PrimaryBrush}" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="72" SharedSizeGroup="CourseCode" />
                                    <ColumnDefinition Width="170" SharedSizeGroup="CourseName" />
                                    <ColumnDefinition Width="58" SharedSizeGroup="CourseSections" />
                                    <ColumnDefinition Width="98" SharedSizeGroup="CourseProfessor" />
                                    <ColumnDefinition Width="52" SharedSizeGroup="CourseType" />
                                    <ColumnDefinition Width="68" SharedSizeGroup="CourseGrade" />
                                    <ColumnDefinition Width="74" SharedSizeGroup="CourseHours" />
                                    <ColumnDefinition Width="70" SharedSizeGroup="CourseBlocks" />
                                    <ColumnDefinition Width="112" SharedSizeGroup="CourseCoteach" />
                                    <ColumnDefinition Width="112" SharedSizeGroup="CourseUnavailableRooms" />
                                    <ColumnDefinition Width="112" SharedSizeGroup="CourseFixedRooms" />
                                    <ColumnDefinition Width="104" SharedSizeGroup="CourseFixedTimes" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="교과목" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="이름" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="3" Text="분반" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="4" Text="교수" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="5" Text="유형" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="6" Text="학년" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="7" Text="시수" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="8" Text="블록" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="9" Text="팀티칭 교수" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="10" Text="불가 강의실" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="11" Text="강의실" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="12" Text="시간 고정" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding CourseGroups}"
                                          ItemTemplate="{StaticResource CourseGroupRowTemplate}" />
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsRoomSelected, Converter={StaticResource BoolToVisibility}}" Margin="8" Background="#F3F4F6"
                                    Grid.IsSharedSizeScope="True">
                            <Grid Background="{StaticResource PrimaryBrush}" Height="30" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="58" SharedSizeGroup="RoomId" />
                                    <ColumnDefinition Width="170" SharedSizeGroup="RoomName" />
                                    <ColumnDefinition Width="70" SharedSizeGroup="RoomLab" />
                                    <ColumnDefinition Width="82" SharedSizeGroup="RoomCapacity" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="강의실 ID" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="2" Text="이름" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="3" Text="구분" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                                <TextBlock Grid.Column="4" Text="허용 인원" FontWeight="Bold" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="6,0" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RoomItems}"
                                           ItemTemplate="{StaticResource RoomRowTemplate}" />
                        </StackPanel>

                        <!-- Solve panel -->
                        <StackPanel Margin="32,24"
                                    Visibility="{Binding IsSolveSelected, Converter={StaticResource BoolToVisibility}}">

                            <!-- Action Buttons moved to top -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="시간표 자동 생성 (해 계산)"
                                        Command="{Binding SolveCommand}"
                                        Padding="20,10" FontWeight="Bold" FontSize="13"
                                        Margin="0,0,8,0"
                                        Background="{StaticResource PrimaryBrush}" Foreground="White" />
                                <Button Content="취소" Command="{Binding CancelCommand}"
                                        Padding="14,10" />
                                <Button Content="해 미리보기로 →"
                                        Command="{Binding GoToSelectionCommand}"
                                        Padding="14,10" Margin="8,0,0,0"
                                        Background="#2E7D32" Foreground="White"
                                        Visibility="{Binding IsSolveComplete, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>

                            <TextBlock Text="진행 상황" FontSize="14" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding StatusMessage}" Margin="0,0,0,8" TextWrapping="Wrap" />
                                    <ProgressBar Height="8" Margin="0,0,0,8"
                                                 Maximum="{Binding ProgressTotal}"
                                                 Value="{Binding ProgressCurrent}" />
                                    <TextBlock>
                                        <Run Text="{Binding ProgressCurrent, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding ProgressTotal, Mode=OneWay}" />
                                        <Run Text="   고유해 " />
                                        <Run Text="{Binding UniqueSolutionsFound, Mode=OneWay}" FontWeight="Bold" />
                                        <Run Text=" 개" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Cross 수동 설정" FontSize="14" FontWeight="Bold" />
                                <TextBlock Text=" (?)" FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                           ToolTip="Cross는 두 과목의 분반 시간을 서로 엇갈리게 묶어&#x0a;시간표 공간을 아끼는 설정입니다.&#x0a;공간이 줄어들면 다른 수업을 배치할 여지가 커져&#x0a;해를 더 잘 찾을 수 있습니다.&#x0a;단, 분반 수와 시수가 같은 과목 2개만 묶고,&#x0a;너무 많이 설정하면 오히려 선택지가 줄어들 수 있습니다." />
                            </StackPanel>
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <TextBlock Text="새 Cross 추가"
                                            FontSize="11" FontWeight="Bold"
                                            Foreground="{StaticResource OnSurfaceVariant}"
                                            Margin="0,0,0,4" />
                                            <TextBlock Text=" (?)" FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                            ToolTip="묶을 과목을 정확히 2개 선택하세요.&#x0a;분반 수와 총 시수가 같아야 합니다." />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding CrossCandidateGradeGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:CrossCandidateGradeGroup}">
                                                    <Expander Header="{Binding Header}" IsExpanded="False" Margin="0,0,0,8" Padding="0,4">
                                                        <ctrl:CheckListPickerControl DataContext="{Binding Items}" />
                                                    </Expander>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="등록된 Cross"
                                                FontSize="11" FontWeight="Bold"
                                                Foreground="{StaticResource OnSurfaceVariant}"
                                                Margin="0,0,0,6" />
                                        <ListBox ItemsSource="{Binding CrossGroupItems}"
                                                SelectedItem="{Binding SelectedCrossGroup, Mode=TwoWay}"
                                                DisplayMemberPath="Display"
                                                MinHeight="96" MaxHeight="140" />
                                        <StackPanel  Orientation="Horizontal"  Margin="0,8,0,0">
                                            <Button Content="Cross 추가"
                                            Command="{Binding AddCrossCommand}"
                                            Padding="10,5"
                                            Background="{StaticResource PrimaryBrush}" Foreground="White" />
                                            <Button Content="Cross 삭제"
                                            Click="OnCrossDeleteClick"
                                            Padding="10,5" Margin="8,0,0,0"
                                            HorizontalAlignment="Left"
                                            Background="#BA1A1A" Foreground="White" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Expander Header="고급" Margin="0,0,0,16" FontSize="14" FontWeight="Bold">
                                <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="생성 설정" FontSize="14" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,4" VerticalAlignment="Center">
                                        <TextBlock Text="해 후보 수" />
                                        <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                   ToolTip="자동 생성 후 비교해 볼 시간표 후보 개수입니다.&#x0a;숫자가 클수록 더 많이 찾지만 시간이 더 걸릴 수 있습니다." />
                                    </StackPanel>
                                    <TextBox Grid.Row="0" Grid.Column="1" Padding="6,4" Margin="0,4" Width="120" HorizontalAlignment="Left"
                                             LostFocus="OnNumericTextBoxLostFocus"
                                             Text="{Binding TotalSolutions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableIntText}}" />
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4" VerticalAlignment="Center">
                                        <TextBlock Text="전체 생성 제한 시간 (초)" />
                                        <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                   ToolTip="시간표 전체 생성에 사용할 최대 시간입니다. 한 해를 찾는 시간은 제한하지 않습니다." />
                                    </StackPanel>
                                    <TextBox Grid.Row="1" Grid.Column="1" Padding="6,4" Margin="0,4" Width="120" HorizontalAlignment="Left"
                                             Text="{Binding TimeLimitSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox x:Name="ConsiderRetakeStudentsCheckBox"
                                              Grid.Row="2" Grid.ColumnSpan="2"
                                              IsChecked="{Binding ConsiderRetakeStudents}"
                                              Margin="0,10,0,4"
                                              ToolTip="전필 재수강 과목과 현재 학년 전필이 겹치지 않는 분반을 최소 하나 확보합니다.&#x0a;전필-전필 시간이 모두 겹치면 시간표가 생성되지 않을 수 있습니다.">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="재수강생 고려" />
                                            <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="전필 재수강 과목과 현재 학년 전필이 겹치지 않는 분반을 최소 하나 확보합니다.&#x0a;전필-전필 시간이 모두 겹치면 시간표가 생성되지 않을 수 있습니다." />
                                        </StackPanel>
                                    </CheckBox>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="선호 조건" FontSize="14" FontWeight="Bold" />
                                <TextBlock Text=" (?)" FontSize="12" Foreground="{StaticResource PrimaryBrush}"
                                           ToolTip="시간표가 반드시 지켜야 하는 규칙은 아니지만,&#x0a;가능하면 더 좋은 시간표가 되도록 솔버가 줄이려는 조건입니다." />
                            </StackPanel>
                            <Border Background="#FAFAFA" Padding="16" BorderBrush="{StaticResource OutlineVariant}" BorderThickness="1" Margin="0,0,0,16">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding UseSc01}" Margin="0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="월요일 오전 / 금요일 오후 피하기" />
                                            <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="월요일 이른 시간과 금요일 늦은 시간 수업을 줄여&#x0a;학생·교수 부담을 낮춥니다." />
                                        </StackPanel>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding UseSc02}" Margin="0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="교수별 강의 요일 3일 이내 선호" />
                                            <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="한 교수의 수업이 너무 많은 요일에&#x0a;흩어지지 않도록 합니다." />
                                        </StackPanel>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding UseSc03}" Margin="0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="같은 과목 수업 간격 확보" />
                                            <TextBlock Text=" (?)" Foreground="{StaticResource PrimaryBrush}"
                                                       ToolTip="같은 과목의 여러 수업 블록이&#x0a;너무 붙지 않게 배치합니다." />
                                        </StackPanel>
                                    </CheckBox>
                                </StackPanel>
                            </Border>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
