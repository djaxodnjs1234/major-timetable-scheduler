<UserControl x:Class="TimetableScheduler.Wpf.Views.ManualEditView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
          xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          mc:Ignorable="d"
          Focusable="True"
          d:DataContext="{d:DesignInstance Type=vm:ManualEditViewModel}">
    <UserControl.Resources>
        <Style x:Key="InspectorValueText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="InspectorSectionTitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ManualEditComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManualEditComboBoxItemStyle}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="4" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="수동 편집" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="시간표를 직접 조정한 뒤 저장하면 시간표 선택 화면으로 돌아갑니다."
                           Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="360" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Center: Unified timetable -->
            <Grid Grid.Column="0" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F5F5F5" Padding="12" CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="초기화"
                            Command="{Binding ResetCommand}"
                            Padding="8,4" Margin="20,0,0,0" />
                        <Button Content="↶"
                            Command="{Binding UndoLastMoveCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Button Content="↷"
                            Command="{Binding RedoCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Button Content="선택 해제"
                            Command="{Binding ClearSelectionCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Separator Width="1" Margin="16,4" Background="#AAA" />

                        <Grid Width="180" Height="34" VerticalAlignment="Center">
                            <TextBox x:Name="SaveNameTextBox"
                                 Padding="10,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SaveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="시간표 이름"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8A8A8A"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=SaveNameTextBox, Converter={StaticResource StringNullOrWhiteSpaceToVisibility}}" />
                        </Grid>

                        <Button Content="저장"
                            Command="{Binding SaveTimetableCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#005FB8" />
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="복사본 저장"
                            Command="{Binding SaveCopyCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0">
                    <Grid>
                        <TabControl>
                            <TabItem Header="통합 시간표">
                                <DockPanel>
                                    <ctrl:UnifiedTimetableControl x:Name="GridControl"
                                                              DataContext="{Binding Grid}" />
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="학년별">
                                <TabControl ItemsSource="{Binding GradeViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>

                            <TabItem Header="강의실별">
                                <TabControl ItemsSource="{Binding RoomViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>

                            <TabItem Header="교수별">
                                <TabControl ItemsSource="{Binding ProfessorViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>
                        </TabControl>

                        <ctrl:GradeLegendControl HorizontalAlignment="Right"
                                             VerticalAlignment="Top"
                                             Margin="0,3,12,0" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                    Padding="12,8" Margin="0,8,0,0">
                    <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#444"
                           TextWrapping="Wrap" />
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True" />

            <!-- Right: Inspector + Conflicts -->
            <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1,0,0,0" Background="White" Padding="10,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,0,6">
                        <Expander IsExpanded="True" Margin="0,0,0,8">
                            <Expander.Header>
                                <TextBlock Text="Inspector"
                                       Padding="6,4"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AppOnSurfaceVariant}" />
                            </Expander.Header>

                            <StackPanel Margin="0,6,0,0">
                                <Border MinHeight="44"
                                    Padding="12,8"
                                    Background="#F8F9FA"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="수업을 선택하세요."
                                           Foreground="#666"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                </Border>

                                <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="#F8F9FA"
                                        BorderBrush="#DDD"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="12"
                                        Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedAssignment.CourseName}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding SelectedLocationText}"
                                                   Style="{StaticResource InspectorValueText}" />
                                            <TextBlock Text="{Binding SelectedSlotDisplayText}"
                                                   Style="{StaticResource InspectorValueText}"
                                                   Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="수업 속성"
                                               Style="{StaticResource InspectorSectionTitleText}" />

                                        <TextBlock Text="{Binding SelectedProfessorName, StringFormat= - 교수 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                        <TextBlock Text="{Binding SelectedDurationText, StringFormat= - 수업 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                        <TextBlock Text="{Binding SelectedBlockText, StringFormat= - 블록 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                        <TextBlock Text="{Binding SelectedFixedText, StringFormat= - 고정 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                        <TextBlock Text="{Binding SelectedCoteachText, StringFormat= - 공동강의 교수 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                        <TextBlock Text="{Binding SelectedAllowedRoomsText, StringFormat= - 강의실 : {0}}"
                                               Style="{StaticResource InspectorValueText}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="이동 상태"
                                               Style="{StaticResource InspectorSectionTitleText}" />
                                        <TextBlock Text="{Binding SelectedMoveStateText}"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />

                                        <StackPanel Visibility="{Binding HasAnyConstraintReasons, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="{Binding SelectedBlockedReasonText}"
                                                   FontSize="12"
                                                   Foreground="#BA1A1A"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasBlockingReasons, Converter={StaticResource BoolToVisibility}}" />
                                            <TextBlock Text="{Binding SelectedWarningReasonText}"
                                                   FontSize="12"
                                                   Foreground="#A05A00"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6"
                                                   Visibility="{Binding HasWarningReasons, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Cross 관계"
                                               Style="{StaticResource InspectorSectionTitleText}" />
                                        <TextBlock Text="{Binding SelectedCrossGroupText}"
                                               Style="{StaticResource InspectorValueText}" />
                                    </StackPanel>

                                    <Border Background="#F8F9FA"
                                        BorderBrush="#DDD"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="강의실 변경"
                                                   Style="{StaticResource InspectorSectionTitleText}" />

                                            <TextBlock Text="{Binding SelectedRoomsText}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="None"
                                                   Margin="0,0,0,4"
                                                   Visibility="{Binding HasSingleAssignedRoomDisplay, Converter={StaticResource BoolToVisibility}}" />

                                            <ComboBox ItemsSource="{Binding AvailableRoomOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="RoomId"
                                                  SelectedValue="{Binding NewRoomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="False"
                                                  Margin="0,0,0,12"
                                                  Padding="6,4"
                                                  Visibility="{Binding HasSingleAssignedRoomChangeUi, Converter={StaticResource BoolToVisibility}}" />

                                            <StackPanel Visibility="{Binding HasMultipleAssignedRooms, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="교체할 강의실"
                                                       FontSize="11"
                                                       Foreground="#666"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4" />
                                                <ComboBox ItemsSource="{Binding AssignedRoomOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="RoomId"
                                                      SelectedValue="{Binding SelectedOldRoomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="False"
                                                      Margin="0,0,0,8"
                                                      Padding="6,4" />

                                                <TextBlock Text="새 강의실"
                                                       FontSize="11"
                                                       Foreground="#666"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4" />
                                                <ComboBox ItemsSource="{Binding ReplacementRoomOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="RoomId"
                                                      SelectedValue="{Binding SelectedReplacementRoomId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="False"
                                                      Margin="0,0,0,12"
                                                      Padding="6,4" />
                                            </StackPanel>

                                            <Button Content="✓ Apply"
                                                Command="{Binding ApplyRoomChangeCommand}"
                                                Height="34"
                                                Padding="10,0"
                                                FontWeight="Bold"
                                                Visibility="{Binding HasRoomChangeApplyUi, Converter={StaticResource BoolToVisibility}}">
                                                <Button.Style>
                                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Background" Value="#005FB8" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <TextBlock Text="{Binding RoomChangeStatusMessage}"
                                                   FontSize="12"
                                                   Foreground="#BA1A1A"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0"
                                                   Visibility="{Binding HasRoomChangeStatusMessage, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="True" Margin="0,4,0,8">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Margin="6,4">
                                    <TextBlock Text="제약조건"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AppOnSurfaceVariant}" />
                                    <Border Background="#BA1A1A"
                                        CornerRadius="8"
                                        Padding="6,1"
                                        Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Conflicts.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding Conflicts.Count}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                            </Expander.Header>

                            <Border MinHeight="44"
                                Background="#FAFAFA"
                                BorderBrush="#E1E1E1"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="12,8"
                                Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="현재 제약조건 위반이 없습니다."
                                           Foreground="{StaticResource AppOnSurfaceVariant}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding Conflicts.Count, Converter={StaticResource BoolToVisibility}, ConverterParameter=Zero}" />

                                    <ItemsControl ItemsSource="{Binding Conflicts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ConflictDisplayItem}">
                                                <Border Background="White"
                                                    BorderBrush="#BA1A1A"
                                                    BorderThickness="4,1,1,1"
                                                    CornerRadius="2"
                                                    Padding="12,8"
                                                    Margin="0,0,0,6">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayTitle}"
                                                               FontWeight="Bold"
                                                               Foreground="#BA1A1A"
                                                               FontSize="11"
                                                               TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding DisplayDescription}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
