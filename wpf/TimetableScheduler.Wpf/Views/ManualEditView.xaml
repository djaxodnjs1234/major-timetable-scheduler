<UserControl x:Class="TimetableScheduler.Wpf.Views.ManualEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:slv="clr-namespace:TimetableScheduler.Solver;assembly=TimetableScheduler.Solver"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Focusable="True"
             d:DataContext="{d:DesignInstance Type=vm:ManualEditViewModel}">
    <UserControl.Resources>
        <Style TargetType="{x:Type Expander}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          HorizontalContentAlignment="Stretch">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="Chevron"
                                               Grid.Column="1"
                                               Text="⌄"
                                               FontSize="12"
                                               Foreground="#666"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              ContentSource="Content"
                                              Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Chevron" Property="Text" Value="⌃" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Step header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource StepBadge}">
                    <TextBlock Text="4단계" Style="{StaticResource StepBadgeText}" />
                </Border>
                <TextBlock Text="수동 편집" Style="{StaticResource StepTitle}" />
                <TextBlock Text="시간표를 직접 조정한 뒤 저장하면 시간표 선택 화면으로 돌아갑니다."
                           Style="{StaticResource StepCaption}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Center: Unified timetable -->
        <Grid Grid.Column="0" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#F5F5F5" Padding="12" CornerRadius="4">
                <StackPanel Orientation="Horizontal">
                    <Button Content="🔄 초기화 (베이스로 되돌리기)"
                            Command="{Binding ResetCommand}"
                            Padding="8,4" Margin="20,0,0,0" />
                    <Button Content="↶ 직전 이동 취소"
                            Command="{Binding UndoLastMoveCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                    <Button Content="↷ 앞으로가기"
                            Command="{Binding RedoCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                    <Button Content="선택 해제"
                            Command="{Binding ClearSelectionCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                    <Separator Width="1" Margin="16,4" Background="#AAA" />
                    <Grid Width="180" Height="34" VerticalAlignment="Center">
                        <TextBox Padding="10,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SaveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="시간표 이름"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8A8A8A"
                                   FontSize="12"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SaveName}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Content="💾 저장"
                            Command="{Binding SaveTimetableCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="#005FB8" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0">
                <TabControl>
                    <TabItem Header="통합 시간표">
                        <ctrl:UnifiedTimetableControl x:Name="GridControl"
                                                      DataContext="{Binding Grid}" />
                    </TabItem>
                    <TabItem Header="학년별">
                        <TabControl ItemsSource="{Binding GradeViews}">
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </TabItem>
                    <TabItem Header="강의실별">
                        <TabControl ItemsSource="{Binding RoomViews}">
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </TabItem>
                    <TabItem Header="교수별">
                        <TabControl ItemsSource="{Binding ProfessorViews}">
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                    Padding="12,8" Margin="0,8,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#444" />
            </Border>
        </Grid>

        <!-- Right: Inspector + Conflicts -->
        <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1,0,0,0" Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,4,0,8">
                    <Expander Header="Inspector" IsExpanded="True" Margin="12,10,12,8">
                        <StackPanel Margin="0,8,0,0">
                            <Border MinHeight="48"
                                    Padding="12,10"
                                    Background="#F8F9FA"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="수업을 선택하세요."
                                           Foreground="#666"
                                           FontSize="12" />
                            </Border>

                            <StackPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                                <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedAssignment.CourseName}"
                                                   FontWeight="Bold" FontSize="14" />
                                        <TextBlock Text="{Binding SelectedAssignment.CourseId}"
                                                   FontSize="11" Foreground="#666" Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding SelectedLocationText}"
                                                   FontSize="12" Margin="0,0,0,2" />
                                        <TextBlock Text="{Binding SelectedSlotLabel}"
                                                   FontSize="12" Margin="0,0,0,2" />
                                        <TextBlock Text="{Binding SelectedOccupiedSlotsText, StringFormat=점유 교시: {0}}"
                                                   FontSize="12" Margin="0,0,0,4" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="수업 속성" FontSize="10" Foreground="#999"
                                               FontWeight="Bold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedProfessorName, StringFormat=교수: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedDurationText, StringFormat=수업 길이: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedBlockText, StringFormat=블록: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedFixedText, StringFormat=고정 수업: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedCoteachText, StringFormat=공동강의 교수: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedMultiRoomText, StringFormat=복수 강의실: {0}}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding SelectedAllowedRoomsText, StringFormat=허용 강의실: {0}}"
                                               FontSize="12" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="이동 상태" FontSize="10" Foreground="#999"
                                               FontWeight="Bold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedMoveStateText}"
                                               FontSize="12" FontWeight="Bold" />
                                    <TextBlock Text="{Binding SelectedBlockedReasonText, StringFormat=이동 불가 사유: {0}}"
                                               FontSize="12" Foreground="#BA1A1A" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedWarningReasonText, StringFormat=주의 사유: {0}}"
                                               FontSize="12" Foreground="#A05A00" TextWrapping="Wrap"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="빨간 칸도 확인 팝업에서 승인하면 강제 이동할 수 있습니다. Error가 남으면 저장은 차단됩니다."
                                               FontSize="11" Foreground="#666" TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="Cross 관계" FontSize="10" Foreground="#999"
                                               FontWeight="Bold" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding SelectedCrossGroupText, StringFormat=연결 수업: {0}}"
                                               FontSize="12" TextWrapping="Wrap" />
                                    <TextBlock Text="Cross는 HC-11 학년 충돌만 예외 처리합니다. 교수/강의실/점심/고정/교수불가능시간은 계속 Error입니다."
                                               FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>

                                <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1"
                                        CornerRadius="2"
                                        Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="강의실 변경" FontSize="10" Foreground="#999"
                                                   FontWeight="Bold" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding AvailableRoomIds}"
                                                  SelectedItem="{Binding NewRoomId, Mode=TwoWay}"
                                                  Margin="0,0,0,12" Padding="6,4" />

                                        <Button Content="✓ Apply Changes"
                                                Command="{Binding ApplyRoomChangeCommand}"
                                                Height="34"
                                                Padding="10,0" FontWeight="Bold">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Background" Value="#005FB8" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander IsExpanded="True" Margin="12,6,12,8">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="제약조건 위반" FontSize="11"
                                           FontWeight="Bold" Foreground="#005FB8" />
                                <Border Background="#BA1A1A" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Conflicts.Count}" Foreground="White"
                                               FontSize="10" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Expander.Header>
                        <Border MinHeight="52"
                                Background="#FAFAFA"
                                BorderBrush="#E1E1E1"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="12,8"
                                Margin="0,8,0,0">
                            <Grid>
                                <TextBlock Text="현재 제약조건 위반이 없습니다."
                                           Foreground="#2E7D32"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding Conflicts.Count, Converter={StaticResource BoolToVisibility}, ConverterParameter=Zero}" />
                                <ItemsControl ItemsSource="{Binding Conflicts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type slv:ConflictItem}">
                                            <Border Background="White"
                                                    BorderBrush="#BA1A1A"
                                                    BorderThickness="4,1,1,1"
                                                    CornerRadius="2"
                                                    Padding="12,8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Type}" FontWeight="Bold"
                                                               Foreground="#BA1A1A" FontSize="11" />
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>
        </Grid>
    </Grid>
</UserControl>
