<UserControl x:Class="TimetableScheduler.Wpf.Views.ManualEditView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
          xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
          xmlns:views="clr-namespace:TimetableScheduler.Wpf.Views"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          mc:Ignorable="d"
          Focusable="True"
          d:DataContext="{d:DesignInstance Type=vm:ManualEditViewModel}">
    <UserControl.Resources>
        <Style x:Key="InspectorValueText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="18" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="InspectorSectionTitleText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ManualEditComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
            <Setter Property="MinHeight" Value="28" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManualEditComboBoxItemStyle}" />
            <Setter Property="MaxDropDownHeight" Value="224" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="4" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="수동 편집" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="시간표를 직접 조정한 뒤 저장하면 시간표 선택 화면으로 돌아갑니다."
                           Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="360" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Center: Unified timetable -->
            <Grid Grid.Column="0" Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F5F5F5" Padding="12" CornerRadius="4">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Right"
                                Content="제약조건 수정"
                                Command="{Binding EditConstraintsCommand}"
                                Padding="10,4" Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#107C10" />
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </Button.Style>
                        </Button>
                        <StackPanel Orientation="Horizontal">
                        <Button Content="초기화"
                            Command="{Binding ResetCommand}"
                            Padding="8,4" Margin="20,0,0,0" />
                        <Button Content="↶"
                            Command="{Binding UndoLastMoveCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Button Content="↷"
                            Command="{Binding RedoCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Button Content="선택 해제"
                            Command="{Binding ClearSelectionCommand}"
                            Padding="8,4" Margin="8,0,0,0" />
                        <Separator Width="1" Margin="16,4" Background="#AAA" />

                        <Grid Width="180" Height="34" VerticalAlignment="Center">
                            <TextBox x:Name="SaveNameTextBox"
                                 Padding="10,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SaveName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="시간표 이름"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8A8A8A"
                                   FontSize="12"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=SaveNameTextBox, Converter={StaticResource StringNullOrWhiteSpaceToVisibility}}" />
                        </Grid>

                        <Button Content="{Binding SaveButtonText}"
                            Command="{Binding SaveTimetableCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="#005FB8" />
                                    <Setter Property="Foreground" Value="White" />
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="다른 이름으로 저장"
                            Command="{Binding SaveCopyCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEditingSavedTimetable, Converter={StaticResource BoolToVisibility}}" />
                        <Button Content="Excel 내보내기"
                            Click="OnExportXlsxClick"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center" />
                        <Button Content="전체 검증"
                            Command="{Binding ValidateAllCommand}"
                            Height="34"
                            Padding="12,0" Margin="6,0,0,0"
                            VerticalAlignment="Center" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="6,3,12,6">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="−" Click="OnZoomOutClick" ToolTip="축소" Width="24" Padding="0" />
                                <TextBlock Text="{Binding Zoom.DisplayPercent, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}"
                                           Width="36" TextAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                <Button Content="+" Click="OnZoomInClick" ToolTip="확대" Width="24" Padding="0" />
                                <Button Content="100%" Click="OnZoomResetClick" ToolTip="기본 크기" Margin="3,0,0,0" Padding="4,1" FontSize="9" />
                            </StackPanel>
                            <ctrl:GradeLegendControl DockPanel.Dock="Right" />
                        </DockPanel>
                        <TabControl Grid.Row="1">
                            <TabItem Header="통합 시간표">
                                <DockPanel>
                                    <ctrl:UnifiedTimetableControl x:Name="GridControl"
                                                              DataContext="{Binding Grid}"
                                                              ConnectorScale="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}">
                                        <ctrl:UnifiedTimetableControl.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}"
                                                            ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}" />
                                        </ctrl:UnifiedTimetableControl.LayoutTransform>
                                    </ctrl:UnifiedTimetableControl>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="학년별">
                                <TabControl ItemsSource="{Binding GradeViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                                    <ctrl:TimetableGridControl.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}"
                                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}" />
                                                    </ctrl:TimetableGridControl.LayoutTransform>
                                                </ctrl:TimetableGridControl>
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>

                            <TabItem Header="강의실별">
                                <TabControl ItemsSource="{Binding RoomViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                                    <ctrl:TimetableGridControl.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}"
                                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}" />
                                                    </ctrl:TimetableGridControl.LayoutTransform>
                                                </ctrl:TimetableGridControl>
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>

                            <TabItem Header="교수별">
                                <TabControl ItemsSource="{Binding ProfessorViews}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                            <DockPanel>
                                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                                    <ctrl:TimetableGridControl.LayoutTransform>
                                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}"
                                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ManualEditView}}}" />
                                                    </ctrl:TimetableGridControl.LayoutTransform>
                                                </ctrl:TimetableGridControl>
                                            </DockPanel>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1"
                    Padding="12,8" Margin="0,8,0,0">
                    <ScrollViewer MaxHeight="96"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#444"
                               TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#E0E0E0"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True" />

            <!-- Right: Inspector + Conflicts -->
            <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1,0,0,0" Background="White" Padding="10,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,8,0,0">
                        <StackPanel Margin="0,0,0,6">
                        <Expander IsExpanded="True" Margin="0,0,0,8">
                            <Expander.Header>
                                <TextBlock Text="Inspector"
                                       Padding="6,4"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AppOnSurfaceVariant}" />
                            </Expander.Header>

                            <StackPanel Margin="0,6,0,0">
                                <Border MinHeight="44"
                                    Padding="12,8"
                                    Background="#F8F9FA"
                                    BorderBrush="#DDD"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Visibility="{Binding HasNoInspectorSelection, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="수업을 선택하세요."
                                           Foreground="#666"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                </Border>

                                <StackPanel Visibility="{Binding HasInspectorSelection, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="#F8F9FA"
                                            BorderBrush="#DDD"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding InspectorAssignment.CourseName}"
                                                       FontWeight="Bold"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding SelectedSlotDisplayText}"
                                                       Style="{StaticResource InspectorValueText}" />
                                            <TextBlock Text="{Binding SelectedRoomsText, StringFormat=강의실: {0}}"
                                                       Style="{StaticResource InspectorValueText}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F8F9FA"
                                            BorderBrush="#DDD"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="담당 교수"
                                                       Style="{StaticResource InspectorSectionTitleText}" />
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding ProfessorOptions}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="ProfessorId"
                                                          SelectedValue="{Binding SelectedPrimaryProfessorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          Padding="6,4" />
                                                <Button Grid.Column="2"
                                                        Content="변경"
                                                        Command="{Binding ApplyPrimaryProfessorChangeCommand}"
                                                        MinWidth="58"
                                                        Padding="8,0" />
                                            </Grid>

                                            <TextBlock Text="팀티칭 교수"
                                                       Style="{StaticResource InspectorSectionTitleText}" />
                                            <TextBlock Text="없음"
                                                       FontSize="12"
                                                       Foreground="#666"
                                                       Margin="0,0,0,8"
                                                       Visibility="{Binding HasNoSelectedCoteachProfessors, Converter={StaticResource BoolToVisibility}}" />
                                            <ItemsControl ItemsSource="{Binding SelectedCoteachProfessorOptions}"
                                                          Margin="0,0,0,8"
                                                          Visibility="{Binding HasSelectedCoteachProfessors, Converter={StaticResource BoolToVisibility}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <Button DockPanel.Dock="Right"
                                                                    Content="삭제"
                                                                    Command="{Binding DataContext.RemoveCoteachProfessorCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                    CommandParameter="{Binding ProfessorId}"
                                                                    MinWidth="48"
                                                                    Padding="6,0"
                                                                    Margin="6,0,0,0" />
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding AddableCoteachProfessorOptions}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="ProfessorId"
                                                          SelectedValue="{Binding SelectedCoteachProfessorId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          Padding="6,4" />
                                                <Button Grid.Column="2"
                                                        Content="추가"
                                                        Command="{Binding AddCoteachProfessorCommand}"
                                                        MinWidth="58"
                                                        Padding="8,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F8F9FA"
                                            BorderBrush="#DDD"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="강의실"
                                                       Style="{StaticResource InspectorSectionTitleText}" />
                                            <ItemsControl ItemsSource="{Binding AssignedRoomOptions}"
                                                          Margin="0,0,0,8">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <Button DockPanel.Dock="Right"
                                                                    Content="삭제"
                                                                    Command="{Binding DataContext.RemoveAssignedRoomCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                    CommandParameter="{Binding RoomId}"
                                                                    MinWidth="48"
                                                                    Padding="6,0"
                                                                    Margin="6,0,0,0" />
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="Consolas"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding AddableRoomOptions}"
                                                          DisplayMemberPath="DisplayText"
                                                          SelectedValuePath="RoomId"
                                                          SelectedValue="{Binding SelectedRoomToAddId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="False"
                                                          FontFamily="Consolas"
                                                          Padding="6,4" />
                                                <Button Grid.Column="2"
                                                        Content="추가"
                                                        Command="{Binding AddSelectedRoomToAssignmentCommand}"
                                                        MinWidth="58"
                                                        Padding="8,0" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="선택 블럭 삭제"
                                                Command="{Binding DeleteSelectedBlockCommand}"
                                                Height="34"
                                                Padding="10,0"
                                                FontWeight="Bold" />
                                        <CheckBox Grid.Column="2"
                                                  Content="해당 과목 전체 삭제"
                                                  IsChecked="{Binding DeleteEntireSelectedCourse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  FontSize="11" />
                                    </Grid>

                                    <TextBlock Text="{Binding RoomChangeStatusMessage}"
                                               FontSize="12"
                                               Foreground="#BA1A1A"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding HasRoomChangeStatusMessage, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="True" Margin="0,4,0,8">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal" Margin="6,4">
                                    <TextBlock Text="제약조건"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AppOnSurfaceVariant}" />
                                    <Border Background="#BA1A1A"
                                        CornerRadius="8"
                                        Padding="6,1"
                                        Margin="8,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConflictGroups.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding ConflictGroups.Count}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                    </Border>
                                </StackPanel>
                            </Expander.Header>

                            <Border MinHeight="44"
                                Background="#FAFAFA"
                                BorderBrush="#E1E1E1"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="12,8"
                                Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="현재 제약조건 위반이 없습니다."
                                           Foreground="{StaticResource AppOnSurfaceVariant}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ConflictGroups.Count, Converter={StaticResource BoolToVisibility}, ConverterParameter=Zero}" />

                                    <ScrollViewer MaxHeight="336"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding ConflictGroups}">
                                            <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ConflictDisplayItem}">
                                                <Expander IsExpanded="False"
                                                          Margin="0,0,0,6">
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Margin="0,2,0,2">
                                                            <TextBlock Text="{Binding DisplayTitle}"
                                                                       FontWeight="Bold"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                        <Setter Property="Foreground" Value="#BA1A1A" />
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <Border Background="White"
                                                            BorderThickness="4,1,1,1"
                                                            CornerRadius="2"
                                                            Padding="12,8">
                                                        <Border.Style>
                                                            <Style TargetType="{x:Type Border}">
                                                                <Setter Property="BorderBrush" Value="#BA1A1A" />
                                                                <Setter Property="Background" Value="#FFF8F8" />
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <ItemsControl ItemsSource="{Binding Lines}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Label}"
                                                                                       Grid.Column="0"
                                                                                       FontSize="11"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="0,1,6,0"
                                                                                       VerticalAlignment="Top">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                                        <Setter Property="Foreground" Value="#BA1A1A" />
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding Text}"
                                                                                       Grid.Column="1"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,1,0,0"
                                                                                       Visibility="{Binding IsCourse, Converter={StaticResource BoolToVisibility}}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                                        <Setter Property="Foreground" Value="#111827" />
                                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Label}" Value="관련 수업:">
                                                                                                <Setter Property="Foreground" Value="#6B7280" />
                                                                                                <Setter Property="FontWeight" Value="Normal" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding Text}"
                                                                                       Grid.Column="1"
                                                                                       FontSize="11"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,1,0,0"
                                                                                       Visibility="{Binding IsCourse, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                                        <Setter Property="Foreground" Value="#BA1A1A" />
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </Expander>
                                            </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Expander>

                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="StagingDropHost"
                            Grid.Row="0"
                            Background="#FAFAFA"
                            BorderBrush="#D8DEE8"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="10"
                            Margin="0,0,0,8"
                            AllowDrop="True"
                            DragOver="OnStagingDragOver"
                            Drop="OnStagingDrop"
                            MouseLeftButtonDown="OnStagingEmptyMouseDown">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,5">
                                <Border DockPanel.Dock="Right"
                                        Background="#005FB8"
                                        CornerRadius="8"
                                        Padding="5,0"
                                        Margin="8,0,0,0"
                                        Visibility="{Binding HasStagedBlocks, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding StagedBlockCount}"
                                               Foreground="White"
                                               FontSize="9"
                                               FontWeight="Bold" />
                                </Border>
                                <TextBlock Text="블럭 보관함"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AppOnSurfaceVariant}"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                            <Button Grid.Row="2"
                                    Content="선택 블럭 빼기"
                                    Command="{Binding StageSelectedBlockCommand}"
                                    Height="28"
                                    Padding="10,0"
                                    FontWeight="Bold"
                                    Margin="0,0,0,6" />

                            <Grid Grid.Row="1"
                                  MinHeight="72"
                                  Visibility="{Binding HasStagedBlocks, Converter={StaticResource BoolToVisibility}}">
                                <ScrollViewer MaxHeight="112"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="StagedBlocksHost"
                                                HorizontalAlignment="Stretch" />
                                </ScrollViewer>
                            </Grid>

                            <ScrollViewer Grid.Row="3"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <Border
                                    Background="White"
                                    BorderBrush="#E1E5EC"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="6"
                                    Margin="0,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="블럭 추가"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AppOnSurfaceVariant}"
                                               Margin="0,0,0,6" />

                                    <TextBlock Text="교과목명"
                                               FontSize="10"
                                               Foreground="#666"
                                               Margin="0,0,0,3" />
                                    <TextBox Text="{Binding NewBlockCourseName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4"
                                             Margin="0,0,0,6" />

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="교수명"
                                                       FontSize="10"
                                                       Foreground="#666"
                                                       Margin="0,0,0,3" />
                                            <TextBox Text="{Binding NewBlockProfessorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="학년"
                                                       FontSize="10"
                                                       Foreground="#666"
                                                       Margin="0,0,0,3" />
                                            <ComboBox ItemsSource="{Binding ManualBlockGradeOptions}"
                                                      SelectedItem="{Binding NewBlockGrade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Padding="6,4" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="수업시수"
                                                       FontSize="10"
                                                       Foreground="#666"
                                                       Margin="0,0,0,3" />
                                            <ComboBox ItemsSource="{Binding ManualBlockWeeklyHourOptions}"
                                                      SelectedItem="{Binding NewBlockRowSpan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Padding="6,4" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="강의실"
                                                       FontSize="10"
                                                       Foreground="#666"
                                                       Margin="0,0,0,3" />
                                            <TextBox Text="{Binding NewBlockRoomName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="6,4" />
                                        </StackPanel>
                                    </Grid>

                                    <Expander Header="고급 설정"
                                              IsExpanded="False"
                                              Margin="0,0,0,8">
                                        <Grid Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <CheckBox Content="블럭구조 사용"
                                                          IsChecked="{Binding IsNewBlockStructureEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          FontSize="10"
                                                          Foreground="#666"
                                                          Margin="0,0,0,3" />
                                                <ComboBox ItemsSource="{Binding NewBlockStructureOptions}"
                                                          SelectedItem="{Binding NewBlockStructureText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding IsNewBlockStructureEnabled}"
                                                          ToolTip="수업시수 합계에 맞는 구조만 선택할 수 있습니다."
                                                          Padding="6,4" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="분반 갯수"
                                                           FontSize="10"
                                                           Foreground="#666"
                                                           Margin="0,0,0,3" />
                                                <TextBox Text="{Binding NewBlockSectionCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Padding="6,4" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander>

                                    <Button Content="보관함에 추가"
                                            Command="{Binding AddManualBlockToStagingCommand}"
                                            Height="30"
                                            Padding="8,0" />

                                    <TextBlock Text="{Binding ManualBlockStatusMessage}"
                                               FontSize="11"
                                               Foreground="#BA1A1A"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"
                                               Visibility="{Binding HasManualBlockStatusMessage, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
