<UserControl x:Class="TimetableScheduler.Wpf.Views.TimetableSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TimetableSelectionViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource StepBadge}">
                    <TextBlock Text="1" Style="{StaticResource StepBadgeText}" />
                </Border>
                <TextBlock Text="시간표 선택" Style="{StaticResource StepTitle}" />
                <TextBlock Text="저장된 시간표를 확인하거나 새 시간표를 만듭니다."
                           Style="{StaticResource StepCaption}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: saved timetable list -->
        <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="12,10"
                        BorderBrush="#CCC" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="저장된 시간표" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="📄 Excel 내보내기"
                                    Click="OnExportXlsxClick"
                                    IsEnabled="{Binding HasSelection}"
                                    Padding="6,3" FontSize="11" />
                        </StackPanel>
                        <Button Content="+ 새 시간표 만들기"
                                Command="{Binding CreateNewCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <Border DockPanel.Dock="Top" Background="#FAFAFA" Padding="16,24"
                        Visibility="{Binding HasNoTimetable, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Foreground="#888" TextWrapping="Wrap" LineHeight="20">
                        저장된 시간표가 없습니다.<LineBreak />
                        수동 편집 화면에서 시간표를 저장하세요.
                    </TextBlock>
                </Border>

                <!-- List -->
                <ListBox ItemsSource="{Binding SavedTimetables}"
                         SelectedItem="{Binding SelectedTimetable, Mode=TwoWay}"
                         BorderThickness="0" Background="White">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                        <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                   FontSize="11" Foreground="#888" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="편집"
                                                Command="{Binding DataContext.EditCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,3" Margin="8,0,0,0"
                                                Background="#005FB8" Foreground="White"
                                                FontSize="11" />
                                        <Button Content="삭제"
                                                Click="OnDeleteClick"
                                                Tag="{Binding}"
                                                Padding="6,3" Margin="4,0,0,0"
                                                Background="#BA1A1A" Foreground="White"
                                                FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right: preview -->
        <Grid Grid.Column="1">
            <Border Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="0"
                    Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="시간표를 선택하면 미리보기가 표시됩니다."
                           Foreground="#888" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Border>
            <Grid Margin="8"
                  Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <TabControl SelectedIndex="{Binding SelectedPreviewTabIndex, Mode=TwoWay}">
                <TabItem Header="통합 시간표">
                    <DockPanel>
                        <ctrl:UnifiedTimetableControl DataContext="{Binding Preview}" />
                    </DockPanel>
                </TabItem>
                <TabItem Header="학년별">
                    <TabControl ItemsSource="{Binding GradeViews}">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <DockPanel>
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </TabItem>
                <TabItem Header="강의실별">
                    <TabControl ItemsSource="{Binding RoomViews}">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <DockPanel>
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </TabItem>
                <TabItem Header="교수별">
                    <TabControl ItemsSource="{Binding ProfessorViews}">
                        <TabControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                                <DockPanel>
                                    <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </TabItem>
            </TabControl>
                <ctrl:GradeLegendControl HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,3,12,0" />
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
