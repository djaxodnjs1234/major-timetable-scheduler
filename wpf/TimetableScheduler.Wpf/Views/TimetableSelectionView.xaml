<UserControl x:Class="TimetableScheduler.Wpf.Views.TimetableSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TimetableSelectionViewModel}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" Padding="12" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="시간표 선택:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="Bold" />
                <ComboBox Width="500"
                          ItemsSource="{Binding Solutions}"
                          SelectedItem="{Binding SelectedSolution, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="총점 " />
                                <TextBlock Text="{Binding Score.Total, StringFormat=F3}" FontWeight="Bold" />
                                <TextBlock Text="  (SC01=" />
                                <TextBlock Text="{Binding Score.Sc01, StringFormat=F2}" />
                                <TextBlock Text=" SC02=" />
                                <TextBlock Text="{Binding Score.Sc02, StringFormat=F2}" />
                                <TextBlock Text=" SC03=" />
                                <TextBlock Text="{Binding Score.Sc03, StringFormat=F2}" />
                                <TextBlock Text=")" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="{Binding Solutions.Count, StringFormat={}총 {0}개 후보}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="#666" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0">
            <ctrl:TimetableGridControl DataContext="{Binding Preview}" />
        </Border>
    </Grid>
</UserControl>
