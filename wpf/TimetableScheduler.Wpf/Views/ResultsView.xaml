<UserControl x:Class="TimetableScheduler.Wpf.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:grid="clr-namespace:TimetableScheduler.ViewModel.Grid;assembly=TimetableScheduler.ViewModel"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:conv="clr-namespace:TimetableScheduler.Wpf.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ResultsViewModel}">
    <UserControl.Resources>
        <conv:DensityToBrushConverter x:Key="DensityToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="3" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="해 미리보기" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="생성된 시간표 후보를 비교하고 편집할 해를 고릅니다."
                               Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top: 해 밀도 미리보기 카드 스트립 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1"
                Padding="8" Margin="0,0,0,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="선택한 해 수동 편집 →"
                        Command="{Binding EditSelectedCommand}"
                        VerticalAlignment="Center" Margin="8,0,0,0"
                        Padding="14,10" FontWeight="Bold"
                        Background="#2E7D32" Foreground="White" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SolutionCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SolutionCardViewModel}">
                            <Border Margin="4,2" Padding="8,6" CornerRadius="6"
                                    Background="White" Cursor="Hand"
                                    MouseLeftButtonDown="OnCardMouseDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter Property="BorderBrush" Value="#DDD" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="#1E40AF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                     <Viewbox MaxHeight="120" Stretch="Uniform" Margin="0,0,0,6">
<Grid>
                                         <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="28" />
                                         </Grid.ColumnDefinitions>

                                        <ItemsControl Grid.ColumnSpan="5" ItemsSource="{Binding PreviewRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:MiniPreviewRow}">
                                                    <Grid Margin="0,1,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="28" />
                                                            <ColumnDefinition Width="28" />
                                                            <ColumnDefinition Width="28" />
                                                            <ColumnDefinition Width="28" />
                                                            <ColumnDefinition Width="28" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Grid.ColumnSpan="5"
                                                                Height="16"
                                                                Margin="1,0"
                                                                Background="White"
                                                                BorderBrush="#E5E7EB"
                                                                BorderThickness="1"
                                                                Visibility="{Binding IsLunch, Converter={StaticResource BoolToVisibility}}" />
                                                        <ItemsControl Grid.Column="0"
                                                                      Grid.ColumnSpan="5"
                                                                      ItemsSource="{Binding Cells}"
                                                                      Visibility="{Binding IsLunch, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Columns="5" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:MiniPreviewCell}">
                                                                    <Border Margin="1,0"
                                                                            Height="16"
                                                                             CornerRadius="2"
                                                                             BorderBrush="#D1D5DB"
                                                                             BorderThickness="1"
                                                                             Background="{Binding Density, Converter={StaticResource DensityToBrush}}">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="False">
                                                                                        <Setter Property="Background" Value="White" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    </Viewbox>
                                    <DockPanel LastChildFill="False">
                                         <Button DockPanel.Dock="Right"
                                                 Content="보관"
                                                 Padding="8,2"
                                                 FontSize="10"
                                                 Command="{Binding DataContext.KeepSolutionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"
                                                 Visibility="{Binding IsKept, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />
                                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                             <TextBlock Text="{Binding Rank, StringFormat={}해 {0}}"
                                                        FontSize="10" Foreground="#666"
                                                        VerticalAlignment="Center" />
                                             <TextBlock Text="{Binding NormalizedScore, StringFormat={}{0:F1}점}"
                                                        FontSize="11" FontWeight="Bold"
                                                        Foreground="#1E40AF"
                                                        VerticalAlignment="Center" Margin="8,0,0,0" />
                                         </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Margin="0,0,0,0">
            <TabItem Header="통합 시간표">
                <DockPanel>
                    <ctrl:GradeLegendControl DockPanel.Dock="Top"
                                             HorizontalAlignment="Right"
                                             Margin="0,6,12,4" />
                    <ctrl:UnifiedTimetableControl DataContext="{Binding Unified}" />
                </DockPanel>
            </TabItem>

            <TabItem Header="학년별">
                <TabControl ItemsSource="{Binding GradeViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:GradeLegendControl DockPanel.Dock="Top"
                                                         HorizontalAlignment="Right"
                                                         Margin="0,6,12,4" />
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="강의실별">
                <TabControl ItemsSource="{Binding RoomViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:GradeLegendControl DockPanel.Dock="Top"
                                                         HorizontalAlignment="Right"
                                                         Margin="0,6,12,4" />
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="교수별">
                <TabControl ItemsSource="{Binding ProfessorViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:GradeLegendControl DockPanel.Dock="Top"
                                                         HorizontalAlignment="Right"
                                                         Margin="0,6,12,4" />
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>
        </TabControl>
        </Grid>
    </Grid>
</UserControl>

