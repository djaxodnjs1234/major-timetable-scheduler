<UserControl x:Class="TimetableScheduler.Wpf.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:grid="clr-namespace:TimetableScheduler.ViewModel.Grid;assembly=TimetableScheduler.ViewModel"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ResultsViewModel}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top: 해 선택 + 점수 + 옵션 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="12" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="해 선택:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="Bold" />
                <ComboBox Width="450"
                          ItemsSource="{Binding Solutions}"
                          SelectedItem="{Binding SelectedSolution, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="총점 " />
                                <TextBlock Text="{Binding Score.Total, StringFormat=F3}" FontWeight="Bold" />
                                <TextBlock Text="  (SC01=" />
                                <TextBlock Text="{Binding Score.Sc01, StringFormat=F2}" />
                                <TextBlock Text=" SC02=" />
                                <TextBlock Text="{Binding Score.Sc02, StringFormat=F2}" />
                                <TextBlock Text=" SC03=" />
                                <TextBlock Text="{Binding Score.Sc03, StringFormat=F2}" />
                                <TextBlock Text=")" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Score breakdown -->
        <Border Grid.Row="1" Background="White" Padding="12,8" Margin="0,8,0,0"
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="SC-01 " Foreground="#666" />
                    <TextBlock Text="{Binding SelectedSolution.Score.Sc01, StringFormat=F3}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="SC-02 " Foreground="#666" />
                    <TextBlock Text="{Binding SelectedSolution.Score.Sc02, StringFormat=F3}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="SC-03 " Foreground="#666" />
                    <TextBlock Text="{Binding SelectedSolution.Score.Sc03, StringFormat=F3}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total " Foreground="#666" />
                    <TextBlock Text="{Binding SelectedSolution.Score.Total, StringFormat=F3}"
                               FontWeight="Bold" FontSize="14" Foreground="#005FB8" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="32,0,0,0">
                    <TextBlock Text="범례:" Foreground="#666" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#FFF9C4" Width="20" Height="14" Margin="2,0" />
                    <TextBlock Text="1학년" FontSize="11" Margin="2,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#DCEDC8" Width="20" Height="14" Margin="2,0" />
                    <TextBlock Text="2학년" FontSize="11" Margin="2,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#BBDEFB" Width="20" Height="14" Margin="2,0" />
                    <TextBlock Text="3학년" FontSize="11" Margin="2,0,8,0" VerticalAlignment="Center" />
                    <Border Background="#FFCDD2" Width="20" Height="14" Margin="2,0" />
                    <TextBlock Text="4학년" FontSize="11" Margin="2,0,8,0" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="2" Margin="0,8,0,0">
            <TabItem Header="통합 시간표">
                <ctrl:UnifiedTimetableControl DataContext="{Binding Unified}" />
            </TabItem>

            <TabItem Header="학년별">
                <TabControl ItemsSource="{Binding GradeViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="강의실별">
                <TabControl ItemsSource="{Binding RoomViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="교수별">
                <TabControl ItemsSource="{Binding ProfessorViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <ctrl:TimetableGridControl DataContext="{Binding Grid}" />
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
