<UserControl x:Class="TimetableScheduler.Wpf.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:grid="clr-namespace:TimetableScheduler.ViewModel.Grid;assembly=TimetableScheduler.ViewModel"
             xmlns:ctrl="clr-namespace:TimetableScheduler.Wpf.Controls"
             xmlns:conv="clr-namespace:TimetableScheduler.Wpf.Converters"
             xmlns:views="clr-namespace:TimetableScheduler.Wpf.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ResultsViewModel}">
    <UserControl.Resources>
        <conv:DensityToBrushConverter x:Key="DensityToBrush" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Border Grid.Row="0" Style="{StaticResource StepHeaderBar}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Content="뒤로가기"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource HeaderBackButton}" />
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="3" Style="{StaticResource StepBadgeText}" />
                    </Border>
                    <TextBlock Text="해 미리보기" Style="{StaticResource StepTitle}" />
                    <TextBlock Text="생성된 시간표 후보를 비교하고 편집할 해를 고릅니다."
                               Style="{StaticResource StepCaption}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top: 해 밀도 미리보기 카드 스트립 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1"
                Padding="6" Margin="0,0,0,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="선택한 해 수동 편집 →"
                        Command="{Binding EditSelectedCommand}"
                        VerticalAlignment="Center" Margin="8,0,0,0"
                        Padding="12,6" FontWeight="Bold"
                        Background="#2E7D32" Foreground="White" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SolutionCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SolutionCardViewModel}">
                            <Border Margin="3,1" Padding="6,4" CornerRadius="6"
                                    Background="White" Cursor="Hand"
                                    MouseLeftButtonDown="OnCardMouseDown">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter Property="BorderBrush" Value="#DDD" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="#1E40AF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                     <Viewbox MaxHeight="84" Stretch="Uniform" Margin="0,0,0,4">
<Grid>
                                         <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="24" />
                                         </Grid.ColumnDefinitions>

                                        <ItemsControl Grid.ColumnSpan="5" ItemsSource="{Binding PreviewRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:MiniPreviewRow}">
                                                    <Grid Margin="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="24" />
                                                        </Grid.ColumnDefinitions>
                                                        <ItemsControl Grid.Column="0"
                                                                      Grid.ColumnSpan="5"
                                                                      ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <UniformGrid Columns="5" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type vm:MiniPreviewCell}">
                                                                    <Border Margin="0"
                                                                            Height="12"
                                                                             CornerRadius="1"
                                                                             BorderBrush="#E2E8F0"
                                                                             BorderThickness="0.5">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{Binding Density, Converter={StaticResource DensityToBrush}}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsOccupied}" Value="False">
                                                                                        <Setter Property="Background" Value="#F8FAFC" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsLunch}" Value="True">
                                                                                        <Setter Property="Background" Value="#E2E8F0" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                    </Viewbox>
                                    <DockPanel LastChildFill="False">
                                         <Button DockPanel.Dock="Right"
                                                 Content="보관"
                                                 Padding="6,0"
                                                 Height="20"
                                                 MinWidth="38"
                                                 FontSize="10"
                                                 BorderThickness="1"
                                                 Background="#F8FAFC"
                                                 BorderBrush="#CBD5E1"
                                                 Foreground="#334155"
                                                 Margin="12,0,0,0"
                                                 Command="{Binding DataContext.KeepSolutionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                 CommandParameter="{Binding}"
                                                 Visibility="{Binding IsKept, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}" />
                                         <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                             <TextBlock Text="{Binding Rank, StringFormat={}해 {0}}"
                                                        FontSize="10" Foreground="#666"
                                                        VerticalAlignment="Center" />
                                             <TextBlock Text="{Binding NormalizedScore, StringFormat={}{0:F1}점}"
                                                        FontSize="11" FontWeight="Bold"
                                                        Foreground="#1E40AF"
                                                        VerticalAlignment="Center" Margin="10,0,0,0" />
                                         </StackPanel>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Tabs -->
        <Grid Grid.Row="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="−" Click="OnZoomOutClick" ToolTip="축소" Width="24" Padding="0" />
                <TextBlock Text="{Binding Zoom.DisplayPercent, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}"
                           Width="36" TextAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                <Button Content="+" Click="OnZoomInClick" ToolTip="확대" Width="24" Padding="0" />
                <Button Content="100%" Click="OnZoomResetClick" ToolTip="기본 크기" Margin="3,0,0,0" Padding="4,1" FontSize="9" />
            </StackPanel>
            <ctrl:GradeLegendControl DockPanel.Dock="Right" />
        </DockPanel>
        <TabControl Grid.Row="1" Margin="0,0,0,0">
            <TabItem Header="통합 시간표">
                <DockPanel>
                    <ctrl:UnifiedTimetableControl DataContext="{Binding Unified}">
                        <ctrl:UnifiedTimetableControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}"
                                            ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}" />
                        </ctrl:UnifiedTimetableControl.LayoutTransform>
                    </ctrl:UnifiedTimetableControl>
                </DockPanel>
            </TabItem>

            <TabItem Header="학년별">
                <TabControl ItemsSource="{Binding GradeViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                    <ctrl:TimetableGridControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}"
                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}" />
                                    </ctrl:TimetableGridControl.LayoutTransform>
                                </ctrl:TimetableGridControl>
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="강의실별">
                <TabControl ItemsSource="{Binding RoomViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                    <ctrl:TimetableGridControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}"
                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}" />
                                    </ctrl:TimetableGridControl.LayoutTransform>
                                </ctrl:TimetableGridControl>
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>

            <TabItem Header="교수별">
                <TabControl ItemsSource="{Binding ProfessorViews}">
                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:NamedGridViewModel}">
                            <DockPanel>
                                <ctrl:TimetableGridControl DataContext="{Binding Grid}">
                                    <ctrl:TimetableGridControl.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}"
                                                        ScaleY="{Binding Zoom.Scale, RelativeSource={RelativeSource AncestorType={x:Type views:ResultsView}}}" />
                                    </ctrl:TimetableGridControl.LayoutTransform>
                                </ctrl:TimetableGridControl>
                            </DockPanel>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </TabItem>
        </TabControl>
        </Grid>
        </Grid>
    </Grid>
</UserControl>

