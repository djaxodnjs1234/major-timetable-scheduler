<Application x:Class="TimetableScheduler.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TimetableScheduler.ViewModel.Pages;assembly=TimetableScheduler.ViewModel"
             xmlns:views="clr-namespace:TimetableScheduler.Wpf.Views"
             xmlns:conv="clr-namespace:TimetableScheduler.Wpf.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <conv:OccupiedToBgConverter x:Key="OccupiedToBgConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:GradeToBrushConverter x:Key="GradeToBrush" />
            <conv:IntListToCsvConverter x:Key="IntListToCsv" />

            <Style TargetType="{x:Type Button}">
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="#E5E7EB" />
                        <Setter Property="BorderBrush" Value="#CBD5E1" />
                        <Setter Property="Foreground" Value="#6B7280" />
                        <Setter Property="Opacity" Value="0.65" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Shared design tokens -->
            <SolidColorBrush x:Key="AppPrimary" Color="#005FB8" />
            <SolidColorBrush x:Key="AppOnSurface" Color="#191C21" />
            <SolidColorBrush x:Key="AppOnSurfaceVariant" Color="#5A6068" />

            <!-- Step header: shown at the top of each page so the user knows
                 which stage of the workflow they are on. -->
            <Style x:Key="StepHeaderBar" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="BorderBrush" Value="#E1E2EA" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Padding" Value="20,12" />
            </Style>
            <Style x:Key="StepBadge" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource AppPrimary}" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="9,3" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>
            <Style x:Key="StepBadgeText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style x:Key="StepTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppOnSurface}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="StepCaption" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AppOnSurfaceVariant}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="12,0,0,0" />
            </Style>
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AppPrimary}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>

            <DataTemplate DataType="{x:Type vm:TimetableSelectionViewModel}">
                <views:TimetableSelectionView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DataInputViewModel}">
                <views:DataInputView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
                <views:ResultsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ManualEditViewModel}">
                <views:ManualEditView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
